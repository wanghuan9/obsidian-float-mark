{
	"name": "obsidian-float-mark",
	"version": "0.1.1",
	"description": "飞书式选中浮动快捷操作、正文标注、侧边评论与可选 Lark 同步的 Obsidian 插件。",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"build": "tsc --noEmit && node esbuild.config.mjs production",
		"dev": "node esbuild.config.mjs",
		"release:check": "node scripts/release.mjs --check",
		"release:official": "node scripts/release.mjs --submit-official",
		"release:publish": "node scripts/release.mjs --publish",
		"test": "node test/test-anchors.mjs && node test/test-block-map.mjs && node test/test-reading-selection.mjs && node test/test-reading-view-renderer.mjs"
	},
	"keywords": [
		"obsidian",
		"annotations",
		"comments",
		"lark",
		"feishu"
	],
	"author": "wanghuan",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "^6.38.2",
		"@types/node": "^20.19.0",
		"builtin-modules": "^5.0.0",
		"esbuild": "^0.25.5",
		"obsidian": "^1.8.7",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3"
	}
}
